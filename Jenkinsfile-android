pipeline {
    agent { label 'mac' }

    environment {
        JAVA_HOME = '/Users/enz/Library/Java/JavaVirtualMachines/ms-21.0.10/Contents/Home'
        ANDROID_HOME = '/Users/enz/Library/Android/sdk'
        ANDROID_SDK_ROOT = '/Users/enz/Library/Android/sdk'
        PATH = "${JAVA_HOME}/bin:${ANDROID_HOME}/cmdline-tools/latest/bin:${ANDROID_HOME}/platform-tools:/Users/enz/.npm-global/bin:${env.PATH}"
        NODE_ENV = 'production'
    }

    stages {
        stage('Check Environment') {
            steps {
                sh 'pwd'
                sh 'java -version'
                sh 'node -v'
                sh 'npm -v'
                sh 'adb --version'
                sh 'firebase --version || npx -y firebase-tools --version'
            }
        }

        stage('Install Node Dependencies') {
            steps {
                sh 'npm ci'
            }
        }

        stage('Prepare Android') {
            steps {
                sh 'chmod +x android/gradlew'
                sh 'echo "sdk.dir=/Users/enz/Library/Android/sdk" > android/local.properties'
            }
        }

        stage('Install Fastlane Dependencies') {
            steps {
                dir('android') {
                    sh 'bundle config set path vendor/bundle'
                    sh 'bundle install'
                }
            }
        }

        stage('Build APK and Upload to Firebase') {
            steps {
                dir('android') {
                    withCredentials([
                        file(credentialsId: 'android-upload-keystore', variable: 'ANDROID_KEYSTORE_FILE'),
                        string(credentialsId: 'android-keystore-password', variable: 'ANDROID_KEYSTORE_PASSWORD'),
                        string(credentialsId: 'android-key-alias', variable: 'ANDROID_KEY_ALIAS'),
                        string(credentialsId: 'android-key-password', variable: 'ANDROID_KEY_PASSWORD'),
                        string(credentialsId: 'firebase-token', variable: 'FIREBASE_TOKEN'),
                        string(credentialsId: 'firebase-android-app-id', variable: 'FIREBASE_ANDROID_APP_ID')
                    ]) {
                        sh 'bundle exec fastlane firebase_release'
                    }
                }
            }
        }
    }

    post {
        always {
            dir('android') {
                sh './gradlew --stop || true'
            }

            sh '''
                mkdir -p "$HOME/Desktop/jenkins-artifacts/mobile-android"

                APK_FILE=$(ls android/app/build/outputs/apk/release/*.apk 2>/dev/null | head -1 || true)

                if [ -n "$APK_FILE" ]; then
                    cp -f "$APK_FILE" "$HOME/Desktop/jenkins-artifacts/mobile-android/app-release-${BUILD_NUMBER}.apk"
                    echo "APK copied to Mac Desktop:"
                    ls -lh "$HOME/Desktop/jenkins-artifacts/mobile-android/"
                else
                    echo "No APK file found."
                fi
            '''

            script {
                try {
                    archiveArtifacts artifacts: 'android/app/build/outputs/apk/release/*.apk', allowEmptyArchive: true
                } catch (err) {
                    echo "archiveArtifacts failed, but APK was copied to Mac Desktop."
                    echo "${err}"
                }
            }
        }

        success {
            echo 'Android release APK build and Firebase upload completed successfully.'
        }

        failure {
            echo 'Android APK build or Firebase upload failed. Check console output.'
        }
    }
}