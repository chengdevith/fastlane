pipeline {
    agent { label 'mac' }

    environment {
        JAVA_HOME = '/Users/enz/Library/Java/JavaVirtualMachines/ms-21.0.10/Contents/Home'
        ANDROID_HOME = '/Users/enz/Library/Android/sdk'
        ANDROID_SDK_ROOT = '/Users/enz/Library/Android/sdk'
        PATH = "${JAVA_HOME}/bin:${ANDROID_HOME}/cmdline-tools/latest/bin:${ANDROID_HOME}/platform-tools:${env.PATH}"
        NODE_ENV = 'production'
    }

    stages {
        stage('Check Environment') {
            steps {
                sh 'pwd'
                sh 'xcodebuild -version'
                sh 'xcrun simctl list devices available | head -50'
                sh 'node -v'
                sh 'npm -v'
                sh 'ruby -v'
                sh 'bundle -v'
                sh 'pod --version'
            }
        }

        stage('Install Node Dependencies') {
            steps {
                sh 'npm ci'
            }
        }

        stage('Install iOS Fastlane Dependencies') {
            steps {
                dir('ios') {
                    sh 'bundle config set path vendor/bundle'
                    sh 'bundle install'
                }
            }
        }

        stage('Install iOS Pods') {
            steps {
                dir('ios') {
                    sh 'pod install'
                }
            }
        }

        stage('Build iOS Simulator') {
            steps {
                dir('ios') {
                    sh 'bundle exec fastlane build_simulator'
                }
            }
        }
    }

    post {
        always {
            sh '''
                mkdir -p "$HOME/Desktop/jenkins-artifacts/mobile-ios"

                IOS_APP=$(find ios/build/Build/Products/Debug-iphonesimulator -name "*.app" -type d 2>/dev/null | head -1 || true)

                if [ -n "$IOS_APP" ]; then
                    ditto -c -k --sequesterRsrc --keepParent "$IOS_APP" "$HOME/Desktop/jenkins-artifacts/mobile-ios/ios-simulator-${BUILD_NUMBER}.zip"
                    echo "iOS simulator app copied to Mac Desktop:"
                    ls -lh "$HOME/Desktop/jenkins-artifacts/mobile-ios/"
                else
                    echo "No iOS simulator .app found."
                fi
            '''

            script {
                try {
                    archiveArtifacts artifacts: 'ios/build/Build/Products/Debug-iphonesimulator/*.app/**', allowEmptyArchive: true
                } catch (err) {
                    echo "archiveArtifacts failed, but iOS simulator build may already be copied locally."
                    echo "${err}"
                }
            }
        }

        success {
            echo 'iOS simulator build completed successfully.'
        }

        failure {
            echo 'iOS build failed. Check console output.'
        }
    }
}