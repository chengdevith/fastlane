pipeline {
    agent { label 'mac' }

    environment {
        NODE_ENV = 'production'
        LANG = 'en_US.UTF-8'
        LC_ALL = 'en_US.UTF-8'
    }

    stages {
        stage('Check Environment') {
            steps {
                sh 'pwd'
                sh 'xcodebuild -version'
                sh 'xcrun simctl list devices available | head -50'
                sh 'node -v'
                sh 'npm -v'
                sh 'ruby -v'
                sh 'bundle -v'
                sh 'pod --version'
            }
        }

        stage('Install Node Dependencies') {
            steps {
                sh 'npm ci'
            }
        }

        stage('Install iOS Fastlane Dependencies') {
            steps {
                dir('ios') {
                    sh 'bundle config set path vendor/bundle'
                    sh 'bundle install'
                }
            }
        }

        stage('Install iOS Pods') {
            steps {
                dir('ios') {
                    sh 'bundle exec pod install'
                }
            }
        }

        stage('Build IPA and Upload to Firebase') {
            steps {
                dir('ios') {
                    withCredentials([
                        string(credentialsId: 'firebase-ios-app-id', variable: 'FIREBASE_IOS_APP_ID'),
                        string(credentialsId: 'firebase-token', variable: 'FIREBASE_TOKEN')
                    ]) {
                        sh 'bundle exec fastlane firebase_release'
                    }
                }
            }
        }
    }

    post {
        always {
            sh '''
                mkdir -p "$HOME/Desktop/jenkins-artifacts/mobile-ios"
                mkdir -p artifacts

                IPA_FILE=$(find ios/build -name "*.ipa" -type f 2>/dev/null | head -1 || true)

                if [ -n "$IPA_FILE" ]; then
                    IPA_NAME="SmartServe-${BUILD_NUMBER}.ipa"

                    cp -f "$IPA_FILE" "artifacts/$IPA_NAME"
                    cp -f "$IPA_FILE" "$HOME/Desktop/jenkins-artifacts/mobile-ios/$IPA_NAME"

                    echo "IPA copied:"
                    ls -lh artifacts/
                    echo "Copied to Mac Desktop:"
                    ls -lh "$HOME/Desktop/jenkins-artifacts/mobile-ios/"
                else
                    echo "No IPA file found."
                fi
            '''

            script {
                try {
                    archiveArtifacts artifacts: 'artifacts/*.ipa', allowEmptyArchive: true
                } catch (err) {
                    echo "archiveArtifacts failed, but IPA may already be copied to Mac Desktop."
                    echo "${err}"
                }
            }
        }

        success {
            echo 'iOS IPA build and Firebase upload completed successfully.'
        }

        failure {
            echo 'iOS IPA build or Firebase upload failed. Check console output.'
        }
    }
}